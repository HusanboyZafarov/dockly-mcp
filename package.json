{
  "name": "api-docs-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that fetches and parses API documentation from Postman/OpenAPI URLs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "api-docs-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "js-yaml": "^4.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.0",
    "typescript": "~5.9.3"
  }
}
